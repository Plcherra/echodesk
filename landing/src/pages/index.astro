---
const plans = [
  {
    name: "Free",
    price: "$0",
    period: "/ month",
    minutes: "Trial workspace",
    note: "Explore the app, voice presets, and setup flow before adding a live business line.",
    cta: "Start free",
    href: "mailto:hello@echodesk.us?subject=Start%20EchoDesk%20Free",
    features: ["Mobile app access", "Create a test receptionist", "Preview voice presets", "Connect Google Calendar"],
  },
  {
    name: "Starter",
    price: "$69",
    period: "/ month",
    minutes: "400 minutes included",
    note: "For independent operators and small service businesses that want reliable call coverage.",
    cta: "Choose Starter",
    href: "mailto:hello@echodesk.us?subject=EchoDesk%20Starter",
    featured: true,
    overage: "$0.29 / extra minute",
    features: ["AI call answering", "Calendar booking", "Call history and recordings", "Appointment review"],
  },
  {
    name: "Business",
    price: "$149",
    period: "/ month",
    minutes: "1,200 minutes included",
    note: "For busier teams that need more receptionist coverage across the week.",
    cta: "Choose Business",
    href: "mailto:hello@echodesk.us?subject=EchoDesk%20Business",
    overage: "$0.29 / extra minute",
    features: ["Everything in Starter", "Multiple receptionists", "Higher included usage", "Priority setup support"],
  },
  {
    name: "Enterprise",
    price: "Custom",
    period: "",
    minutes: "Custom minutes",
    note: "For multi-location operators, higher call volume, and custom operational workflows.",
    cta: "Talk to us",
    href: "mailto:hello@echodesk.us?subject=EchoDesk%20Enterprise",
    overage: "Volume pricing",
    features: ["Custom call routing", "Dedicated onboarding", "Compliance review", "Custom reporting"],
  },
];

const features = [
  {
    title: "Answers professionally",
    text: "A calm AI receptionist picks up when your team is busy, closed, or with a customer.",
  },
  {
    title: "Books from real availability",
    text: "EchoDesk checks Google Calendar before offering times and creates appointments in the right calendar.",
  },
  {
    title: "Keeps calls organized",
    text: "Call summaries, recordings, appointments, and follow-up status stay available in the mobile app.",
  },
  {
    title: "Built for service teams",
    text: "Designed for salons, clinics, studios, home services, consultants, and calendar-driven teams.",
  },
];

const testimonials = [
  {
    quote: "The value is simple: customers get an answer, and bookings land in the calendar without us stopping a service.",
    name: "Salon owner",
  },
  {
    quote: "It feels calm and practical. We can see what happened on each call and decide what needs attention.",
    name: "Wellness studio operator",
  },
  {
    quote: "The pricing is easy to understand, and the app makes call handling feel less chaotic.",
    name: "Local service provider",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>EchoDesk | Calm AI receptionist for appointment booking</title>
    <meta
      name="description"
      content="EchoDesk is a calm AI receptionist that answers calls, checks calendar availability, books appointments, and keeps call records organized."
    />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        color-scheme: light;
        --bg: #fbfaf8;
        --surface: #ffffff;
        --surface-soft: #f4f1ee;
        --surface-muted: #ede9e4;
        --ink: #151821;
        --muted: #626873;
        --soft: #8b9099;
        --line: #e6e0da;
        --line-strong: #cfc6bd;
        --brand: #174061;
        --brand-2: #2f9c9d;
        --brand-soft: #e6f3f2;
        --accent: #57609a;
        --sage: #4f8663;
        --amber: #a87635;
        --shadow: 0 24px 70px rgba(32, 36, 42, 0.1);
        --shadow-soft: 0 14px 34px rgba(32, 36, 42, 0.07);
        --radius: 8px;
        --max: 1160px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: var(--ink);
        background: var(--bg);
        -webkit-font-smoothing: antialiased;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        display: block;
        max-width: 100%;
      }

      h1,
      h2,
      h3,
      p {
        margin: 0;
      }

      .shell {
        width: min(var(--max), calc(100% - 40px));
        margin: 0 auto;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 30;
        border-bottom: 1px solid rgba(230, 224, 218, 0.82);
        background: rgba(251, 250, 248, 0.92);
        backdrop-filter: blur(18px);
      }

      .nav {
        min-height: 72px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-weight: 700;
      }

      .brand-mark {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        border: 1px solid rgba(23, 64, 97, 0.12);
        box-shadow: 0 8px 20px rgba(23, 64, 97, 0.08);
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 28px;
        color: var(--muted);
        font-size: 14px;
        font-weight: 600;
      }

      .nav-actions {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .button {
        min-height: 44px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 18px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--surface);
        color: var(--ink);
        font-size: 14px;
        font-weight: 700;
        transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
      }

      .button:hover {
        transform: translateY(-1px);
        border-color: var(--line-strong);
        box-shadow: var(--shadow-soft);
      }

      .button.primary {
        border-color: var(--brand);
        background: var(--brand);
        color: #fff;
      }

      .button.quiet {
        background: transparent;
      }

      .hero {
        padding: 96px 0 58px;
        border-bottom: 1px solid var(--line);
      }

      .hero-copy {
        max-width: 860px;
        margin: 0 auto;
        text-align: center;
      }

      .eyebrow,
      .kicker {
        color: var(--brand-2);
        font-size: 13px;
        font-weight: 700;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 22px;
      }

      .eyebrow::before {
        content: "";
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--brand-2);
      }

      h1 {
        font-size: 64px;
        line-height: 1.05;
        font-weight: 700;
      }

      .hero-subtitle {
        max-width: 690px;
        margin: 24px auto 0;
        color: var(--muted);
        font-size: 20px;
        line-height: 1.65;
      }

      .hero-actions {
        margin-top: 34px;
        display: flex;
        justify-content: center;
        gap: 12px;
        flex-wrap: wrap;
      }

      .hero-note {
        margin-top: 18px;
        color: var(--soft);
        font-size: 14px;
      }

      .hero-media {
        margin-top: 70px;
      }

      .device-stage {
        position: relative;
        min-height: 580px;
      }

      .desktop-frame,
      .phone-frame,
      .customer-frame {
        border: 1px solid rgba(23, 64, 97, 0.1);
        background: #fff;
        box-shadow: var(--shadow);
      }

      .desktop-frame {
        width: min(920px, 100%);
        margin: 0 auto;
        border-radius: 8px;
        overflow: hidden;
      }

      .browser-bar {
        min-height: 42px;
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 0 14px;
        border-bottom: 1px solid var(--line);
        background: #f2eee9;
      }

      .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: #c8c0b7;
      }

      .url-bar {
        height: 24px;
        flex: 1;
        border-radius: 999px;
        background: #fff;
        color: var(--soft);
        display: flex;
        align-items: center;
        padding: 0 12px;
        font-size: 12px;
      }

      .mock-dashboard {
        min-height: 510px;
        display: grid;
        grid-template-columns: 220px 1fr;
        background: var(--surface);
      }

      .mock-sidebar {
        padding: 26px 22px;
        border-right: 1px solid var(--line);
        background: #f8f6f3;
      }

      .mock-logo-row,
      .mock-profile {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .mock-logo-row img {
        width: 34px;
        height: 34px;
        border-radius: 8px;
      }

      .mock-logo-row strong {
        font-size: 15px;
      }

      .mock-nav {
        margin-top: 34px;
        display: grid;
        gap: 10px;
      }

      .mock-nav span {
        border-radius: 8px;
        padding: 11px 12px;
        color: var(--muted);
        font-size: 14px;
        font-weight: 600;
      }

      .mock-nav span.active {
        color: var(--brand);
        background: var(--brand-soft);
      }

      .mock-main {
        padding: 30px;
      }

      .mock-topline {
        display: flex;
        align-items: start;
        justify-content: space-between;
        gap: 18px;
      }

      .mock-topline h3,
      .mini-title {
        font-size: 20px;
        line-height: 1.25;
      }

      .mock-topline p,
      .mini-copy {
        margin-top: 8px;
        color: var(--muted);
        line-height: 1.55;
        font-size: 14px;
      }

      .status-pill,
      .soft-pill,
      .warning-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        min-height: 30px;
        padding: 0 10px;
        font-size: 12px;
        font-weight: 700;
      }

      .status-pill {
        color: var(--sage);
        background: #e5f3e9;
      }

      .soft-pill {
        color: var(--accent);
        background: #eceefa;
      }

      .warning-pill {
        color: #b76d11;
        background: #fff0d7;
      }

      .metric-grid {
        margin-top: 28px;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
      }

      .metric-card,
      .call-row,
      .appointment-row,
      .summary-card {
        border: 1px solid var(--line);
        border-radius: 8px;
        background: #fff;
        box-shadow: 0 10px 22px rgba(32, 36, 42, 0.04);
      }

      .metric-card {
        padding: 18px;
      }

      .metric-card span {
        display: block;
        color: var(--muted);
        font-size: 13px;
        margin-bottom: 10px;
      }

      .metric-card strong {
        font-size: 26px;
      }

      .call-list {
        margin-top: 24px;
        display: grid;
        gap: 12px;
      }

      .call-row {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 16px;
        padding: 16px;
      }

      .call-row strong,
      .appointment-row strong {
        display: block;
        font-size: 15px;
        margin-bottom: 5px;
      }

      .call-row span,
      .appointment-row span {
        color: var(--muted);
        font-size: 13px;
      }

      .phone-frame {
        position: absolute;
        right: 34px;
        bottom: -12px;
        width: 292px;
        border-radius: 34px;
        padding: 12px;
        background: #111827;
      }

      .phone-screen {
        min-height: 510px;
        border-radius: 26px;
        overflow: hidden;
        background: #faf8f5;
      }

      .phone-top {
        height: 34px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 18px;
        color: var(--ink);
        font-size: 12px;
        font-weight: 700;
      }

      .phone-content {
        padding: 22px 18px;
      }

      .incoming-card {
        border-radius: 8px;
        background: var(--brand);
        color: #fff;
        padding: 18px;
      }

      .incoming-card img {
        width: 42px;
        height: 42px;
        border-radius: 8px;
        margin-bottom: 18px;
      }

      .incoming-card h3 {
        font-size: 20px;
      }

      .incoming-card p {
        margin-top: 8px;
        color: rgba(255, 255, 255, 0.74);
        font-size: 13px;
      }

      .waveform {
        margin: 20px 0 4px;
        height: 34px;
        display: flex;
        align-items: center;
        gap: 4px;
      }

      .waveform span {
        width: 4px;
        height: 14px;
        border-radius: 999px;
        background: #6ed0ca;
        animation: signalPulse 1.8s ease-in-out infinite;
      }

      .waveform span:nth-child(2) {
        height: 25px;
        animation-delay: 140ms;
      }

      .waveform span:nth-child(3) {
        height: 18px;
        animation-delay: 280ms;
      }

      .waveform span:nth-child(4) {
        height: 30px;
        animation-delay: 420ms;
      }

      .waveform span:nth-child(5) {
        height: 16px;
        animation-delay: 560ms;
      }

      .transcript {
        margin-top: 16px;
        display: grid;
        gap: 10px;
      }

      .bubble {
        border-radius: 8px;
        padding: 12px;
        font-size: 13px;
        line-height: 1.45;
      }

      .bubble.ai {
        background: #fff;
        border: 1px solid var(--line);
      }

      .bubble.customer {
        background: var(--brand-soft);
        color: var(--brand);
      }

      .trust-row {
        margin-top: 36px;
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1px;
        background: var(--line);
        border: 1px solid var(--line);
        border-radius: 8px;
        overflow: hidden;
      }

      .trust-item {
        background: var(--surface);
        padding: 18px;
        color: var(--muted);
        font-size: 14px;
      }

      .trust-item strong {
        display: block;
        margin-bottom: 5px;
        color: var(--ink);
        font-size: 15px;
      }

      .section {
        padding: 98px 0;
      }

      .section.compact {
        padding: 78px 0;
      }

      .section-header {
        max-width: 700px;
        margin-bottom: 44px;
      }

      .kicker {
        display: block;
        margin-bottom: 12px;
      }

      h2 {
        font-size: 42px;
        line-height: 1.16;
        font-weight: 700;
      }

      .section-copy {
        margin-top: 16px;
        color: var(--muted);
        font-size: 18px;
        line-height: 1.65;
      }

      .pricing-section {
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
        background: var(--surface);
      }

      .pricing-layout {
        display: grid;
        grid-template-columns: 0.82fr 1.18fr;
        gap: 48px;
        align-items: start;
      }

      .pricing-summary {
        position: sticky;
        top: 104px;
      }

      .pricing-note {
        margin-top: 24px;
        padding: 18px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: #f8f6f3;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.6;
      }

      .pricing-note strong {
        color: var(--ink);
      }

      .pricing-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
      }

      .plan {
        min-height: 426px;
        display: flex;
        flex-direction: column;
        padding: 26px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--surface);
        box-shadow: var(--shadow-soft);
      }

      .plan.featured {
        border-color: rgba(23, 64, 97, 0.55);
        box-shadow: 0 22px 54px rgba(23, 64, 97, 0.14);
      }

      .plan-label {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 18px;
      }

      .plan-name {
        font-size: 19px;
      }

      .recommended {
        border: 1px solid rgba(79, 134, 99, 0.24);
        background: rgba(79, 134, 99, 0.1);
        color: var(--sage);
        border-radius: 999px;
        padding: 5px 9px;
        font-size: 12px;
        font-weight: 700;
      }

      .price {
        display: flex;
        align-items: baseline;
        gap: 5px;
        margin-bottom: 9px;
      }

      .price strong {
        font-size: 40px;
        line-height: 1;
      }

      .price span,
      .plan-note,
      .overage {
        color: var(--muted);
      }

      .minutes {
        color: var(--brand);
        font-weight: 700;
        margin-bottom: 10px;
      }

      .plan-note {
        font-size: 14px;
        line-height: 1.55;
      }

      .feature-list {
        list-style: none;
        padding: 0;
        margin: 24px 0;
        display: grid;
        gap: 10px;
        color: var(--muted);
        font-size: 14px;
      }

      .feature-list li {
        display: grid;
        grid-template-columns: 18px 1fr;
        gap: 8px;
      }

      .feature-list li::before {
        content: "";
        width: 8px;
        height: 8px;
        margin-top: 6px;
        border-radius: 50%;
        background: var(--brand-2);
      }

      .plan-footer {
        margin-top: auto;
        display: grid;
        gap: 12px;
      }

      .overage {
        font-size: 13px;
      }

      .features-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 16px;
      }

      .feature-card {
        min-height: 218px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--surface);
        padding: 24px;
      }

      .feature-number {
        width: 34px;
        height: 34px;
        display: grid;
        place-items: center;
        margin-bottom: 28px;
        border-radius: 8px;
        background: var(--brand-soft);
        color: var(--brand);
        font-weight: 700;
      }

      .feature-card h3 {
        font-size: 19px;
        margin-bottom: 12px;
      }

      .feature-card p {
        color: var(--muted);
        line-height: 1.6;
        font-size: 15px;
      }

      .product-section {
        border-top: 1px solid var(--line);
      }

      .mockup-grid {
        display: grid;
        grid-template-columns: 1.04fr 0.96fr;
        gap: 24px;
        align-items: stretch;
      }

      .mockup-stack {
        display: grid;
        gap: 24px;
      }

      .mock-card {
        border: 1px solid var(--line);
        border-radius: 8px;
        background: #fff;
        box-shadow: var(--shadow-soft);
        overflow: hidden;
      }

      .mock-card-pad {
        padding: 26px;
      }

      .phone-device {
        width: 320px;
        margin: 0 auto;
        border-radius: 36px;
        padding: 12px;
        background: #111827;
        box-shadow: var(--shadow);
      }

      .booking-screen {
        min-height: 610px;
        border-radius: 27px;
        background: #fbfaf8;
        overflow: hidden;
      }

      .booking-header {
        padding: 24px 20px 18px;
        border-bottom: 1px solid var(--line);
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .booking-header img {
        width: 38px;
        height: 38px;
        border-radius: 8px;
      }

      .booking-body {
        padding: 20px;
        display: grid;
        gap: 14px;
      }

      .appointment-row {
        padding: 16px;
      }

      .calendar-mock {
        min-height: 360px;
      }

      .calendar-toolbar,
      .summary-toolbar {
        padding: 18px;
        border-bottom: 1px solid var(--line);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }

      .calendar-grid {
        padding: 18px;
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 10px;
      }

      .day-column {
        min-height: 230px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: #faf8f5;
        padding: 10px;
      }

      .day-column strong {
        display: block;
        margin-bottom: 12px;
        font-size: 13px;
      }

      .slot {
        margin-top: 8px;
        padding: 8px;
        border-radius: 8px;
        background: #fff;
        color: var(--muted);
        font-size: 12px;
        line-height: 1.35;
      }

      .slot.booked {
        color: var(--brand);
        background: var(--brand-soft);
        font-weight: 700;
      }

      .summary-card {
        padding: 20px;
      }

      .summary-details {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-top: 18px;
      }

      .summary-details div {
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 12px;
        background: #faf8f5;
      }

      .summary-details span {
        display: block;
        color: var(--muted);
        font-size: 12px;
        margin-bottom: 6px;
      }

      .summary-details strong {
        font-size: 14px;
      }

      .testimonials {
        border-top: 1px solid var(--line);
        background: var(--surface-soft);
      }

      .testimonial-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 16px;
      }

      .testimonial {
        margin: 0;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--surface);
        padding: 26px;
      }

      .testimonial p {
        line-height: 1.65;
        font-size: 16px;
      }

      .testimonial footer {
        margin-top: 20px;
        color: var(--muted);
        font-size: 14px;
        font-weight: 700;
      }

      .final-cta {
        max-width: 720px;
        margin: 0 auto;
        text-align: center;
      }

      .final-cta p {
        margin-top: 18px;
        color: var(--muted);
        line-height: 1.65;
        font-size: 18px;
      }

      .final-actions {
        margin-top: 30px;
        display: flex;
        justify-content: center;
        gap: 12px;
        flex-wrap: wrap;
      }

      .site-footer {
        border-top: 1px solid var(--line);
        padding: 28px 0;
        color: var(--muted);
        font-size: 14px;
      }

      .footer-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        flex-wrap: wrap;
      }

      .footer-links {
        display: flex;
        gap: 20px;
      }

      @keyframes signalPulse {
        0%,
        100% {
          opacity: 0.45;
          transform: scaleY(0.72);
        }

        50% {
          opacity: 1;
          transform: scaleY(1);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }

        .button,
        .waveform span {
          animation: none;
          transition: none;
        }
      }

      @media (max-width: 1080px) {
        .phone-frame {
          right: 0;
        }
      }

      @media (max-width: 980px) {
        .hero {
          padding-top: 76px;
        }

        h1 {
          font-size: 52px;
        }

        .device-stage {
          min-height: auto;
          display: grid;
          gap: 24px;
        }

        .phone-frame {
          position: static;
          width: min(340px, 100%);
          margin: 0 auto;
        }

        .pricing-layout,
        .mockup-grid {
          grid-template-columns: 1fr;
          gap: 32px;
        }

        .pricing-summary {
          position: static;
        }

        .features-grid,
        .trust-row,
        .testimonial-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }

      @media (max-width: 760px) {
        .shell {
          width: min(var(--max), calc(100% - 28px));
        }

        .nav {
          min-height: 66px;
        }

        .nav-links {
          display: none;
        }

        .nav-actions .quiet {
          display: none;
        }

        h1 {
          font-size: 42px;
        }

        h2 {
          font-size: 32px;
        }

        .hero-subtitle,
        .section-copy {
          font-size: 17px;
        }

        .section {
          padding: 72px 0;
        }

        .mock-dashboard {
          grid-template-columns: 1fr;
        }

        .mock-sidebar {
          display: none;
        }

        .mock-main {
          padding: 22px;
        }

        .mock-topline {
          display: grid;
        }

        .metric-grid,
        .pricing-grid,
        .features-grid,
        .trust-row,
        .testimonial-grid,
        .summary-details {
          grid-template-columns: 1fr;
        }

        .calendar-grid {
          grid-template-columns: 1fr;
        }

        .day-column {
          min-height: auto;
        }

        .phone-device {
          width: min(320px, 100%);
        }

        .button {
          width: 100%;
        }

        .nav-actions .button {
          width: auto;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="shell nav">
        <a class="brand" href="#top" aria-label="EchoDesk home">
          <img class="brand-mark" src="/images/echodesk-logo-mark.png" alt="" width="34" height="34" />
          <span>EchoDesk</span>
        </a>
        <nav class="nav-links" aria-label="Primary navigation">
          <a href="#pricing">Pricing</a>
          <a href="#features">Features</a>
          <a href="#product">Product</a>
          <a href="#testimonials">Stories</a>
        </nav>
        <div class="nav-actions">
          <a class="button quiet" href="mailto:hello@echodesk.us">Contact</a>
          <a class="button primary" href="#pricing">See pricing</a>
        </div>
      </div>
    </header>

    <main id="top">
      <section class="hero" aria-labelledby="hero-title">
        <div class="shell">
          <div class="hero-copy">
            <p class="eyebrow">AI receptionist for appointment-based businesses</p>
            <h1 id="hero-title">Turn missed calls into booked appointments.</h1>
            <p class="hero-subtitle">
              EchoDesk answers calls with a calm, professional voice, checks real calendar availability,
              and books customers while your team stays focused on service.
            </p>
            <div class="hero-actions">
              <a class="button primary" href="#pricing">View plans</a>
              <a class="button" href="mailto:hello@echodesk.us?subject=EchoDesk%20demo">Request a demo</a>
            </div>
            <p class="hero-note">Plans start at $69/month. Included minutes, clear overage, no long-term contract.</p>
          </div>

          <div class="hero-media" aria-label="Anonymized EchoDesk product preview">
            <div class="device-stage">
              <div class="desktop-frame" aria-label="Desktop dashboard mockup">
                <div class="browser-bar">
                  <span class="dot"></span>
                  <span class="dot"></span>
                  <span class="dot"></span>
                  <div class="url-bar">echodesk.us/dashboard</div>
                </div>
                <div class="mock-dashboard">
                  <aside class="mock-sidebar">
                    <div class="mock-logo-row">
                      <img src="/images/echodesk-logo-mark.png" alt="" width="34" height="34" />
                      <strong>EchoDesk</strong>
                    </div>
                    <nav class="mock-nav" aria-label="Mock dashboard navigation">
                      <span class="active">Dashboard</span>
                      <span>Calls</span>
                      <span>Appointments</span>
                      <span>Customers</span>
                      <span>Settings</span>
                    </nav>
                  </aside>
                  <section class="mock-main">
                    <div class="mock-topline">
                      <div>
                        <h3>Sarah's Salon</h3>
                        <p>AI receptionist activity for today.</p>
                      </div>
                      <span class="status-pill">Active</span>
                    </div>
                    <div class="metric-grid">
                      <div class="metric-card"><span>Calls handled</span><strong>18</strong></div>
                      <div class="metric-card"><span>Appointments</span><strong>7</strong></div>
                      <div class="metric-card"><span>Avg. response</span><strong>2.1s</strong></div>
                    </div>
                    <div class="call-list">
                      <div class="call-row">
                        <div>
                          <strong>Maya R.</strong>
                          <span>Booked haircut for tomorrow at 10:30 AM</span>
                        </div>
                        <span class="status-pill">Booked</span>
                      </div>
                      <div class="call-row">
                        <div>
                          <strong>Jordan Lee</strong>
                          <span>Asked about color consultation pricing</span>
                        </div>
                        <span class="warning-pill">Review</span>
                      </div>
                      <div class="call-row">
                        <div>
                          <strong>New caller</strong>
                          <span>Requested callback from Downtown Barbershop</span>
                        </div>
                        <span class="soft-pill">Follow up</span>
                      </div>
                    </div>
                  </section>
                </div>
              </div>

              <div class="phone-frame" aria-label="Phone call handling mockup">
                <div class="phone-screen">
                  <div class="phone-top">
                    <span>9:41</span>
                    <span>5G</span>
                  </div>
                  <div class="phone-content">
                    <div class="incoming-card">
                      <img src="/images/echodesk-logo-mark.png" alt="" width="42" height="42" />
                      <h3>Call in progress</h3>
                      <p>New customer - (555) 014-2081</p>
                      <div class="waveform" aria-hidden="true">
                        <span></span><span></span><span></span><span></span><span></span>
                      </div>
                    </div>
                    <div class="transcript">
                      <div class="bubble customer">Do you have anything open tomorrow morning?</div>
                      <div class="bubble ai">Yes. I can book 10:30 AM or 11:15 AM with Sarah.</div>
                      <div class="bubble customer">10:30 works.</div>
                      <div class="bubble ai">You're booked. I'll send the confirmation now.</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="trust-row" aria-label="Product highlights">
              <div class="trust-item"><strong>24/7 coverage</strong>Customers get a polished answer after hours.</div>
              <div class="trust-item"><strong>Calendar-first</strong>Availability comes from the schedule you trust.</div>
              <div class="trust-item"><strong>Mobile control</strong>Review calls, bookings, and recordings from your phone.</div>
              <div class="trust-item"><strong>Clear pricing</strong>Included minutes and a predictable $0.29 overage.</div>
            </div>
          </div>
        </div>
      </section>

      <section class="section pricing-section" id="pricing" aria-labelledby="pricing-title">
        <div class="shell pricing-layout">
          <div class="pricing-summary">
            <p class="kicker">Pricing</p>
            <h2 id="pricing-title">Clear plans built around call minutes.</h2>
            <p class="section-copy">
              Start small, upgrade when call volume grows, and keep busy months predictable with a simple
              $0.29 per minute overage on paid plans.
            </p>
            <div class="pricing-note">
              <strong>Overage:</strong> Starter and Business include extra minutes at $0.29 per minute.
              Enterprise plans can use custom volume pricing.
            </div>
          </div>

          <div class="pricing-grid">
            {
              plans.map((plan) => (
                <article class:list={["plan", { featured: plan.featured }]}>
                  <div class="plan-label">
                    <h3 class="plan-name">{plan.name}</h3>
                    {plan.featured && <span class="recommended">Recommended</span>}
                  </div>
                  <div class="price">
                    <strong>{plan.price}</strong>
                    {plan.period && <span>{plan.period}</span>}
                  </div>
                  <p class="minutes">{plan.minutes}</p>
                  <p class="plan-note">{plan.note}</p>
                  <ul class="feature-list">
                    {plan.features.map((feature) => <li>{feature}</li>)}
                  </ul>
                  <div class="plan-footer">
                    {plan.overage && <p class="overage">Overage: {plan.overage}</p>}
                    <a class:list={["button", { primary: plan.featured }]} href={plan.href}>{plan.cta}</a>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section class="section" id="features" aria-labelledby="features-title">
        <div class="shell">
          <div class="section-header">
            <p class="kicker">What it does</p>
            <h2 id="features-title">A receptionist workflow that stays focused on booking.</h2>
            <p class="section-copy">
              EchoDesk keeps the experience simple: answer, understand, check availability, book,
              and keep a clean record for your team.
            </p>
          </div>
          <div class="features-grid">
            {
              features.map((feature, index) => (
                <article class="feature-card">
                  <div class="feature-number">{index + 1}</div>
                  <h3>{feature.title}</h3>
                  <p>{feature.text}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section class="section product-section" id="product" aria-labelledby="product-title">
        <div class="shell">
          <div class="section-header">
            <p class="kicker">Product preview</p>
            <h2 id="product-title">Staged views of the calls, bookings, and customer context your team sees.</h2>
            <p class="section-copy">
              These mockups use generic data to show the main flow without exposing personal notifications,
              real names, or private phone numbers.
            </p>
          </div>

          <div class="mockup-grid">
            <div class="mock-card mock-card-pad">
              <div class="phone-device" aria-label="Booking confirmation phone mockup">
                <div class="booking-screen">
                  <div class="phone-top">
                    <span>9:41</span>
                    <span>5G</span>
                  </div>
                  <div class="booking-header">
                    <img src="/images/echodesk-logo-mark.png" alt="" width="38" height="38" />
                    <div>
                      <strong>Booking confirmed</strong>
                      <p class="mini-copy">Sarah's Salon</p>
                    </div>
                  </div>
                  <div class="booking-body">
                    <div class="appointment-row">
                      <strong>Maya R.</strong>
                      <span>Haircut - Tomorrow, 10:30 AM</span>
                    </div>
                    <div class="appointment-row">
                      <strong>Confirmation message</strong>
                      <span>Your appointment is confirmed for tomorrow at 10:30 AM.</span>
                    </div>
                    <div class="appointment-row">
                      <strong>Call summary</strong>
                      <span>Caller requested a morning appointment and accepted the first available time.</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="mockup-stack">
              <div class="mock-card calendar-mock" aria-label="Calendar availability mockup">
                <div class="calendar-toolbar">
                  <div>
                    <h3 class="mini-title">Calendar view</h3>
                    <p class="mini-copy">Downtown Barbershop - Week preview</p>
                  </div>
                  <span class="status-pill">Connected</span>
                </div>
                <div class="calendar-grid">
                  <div class="day-column">
                    <strong>Mon</strong>
                    <div class="slot">9:00 AM open</div>
                    <div class="slot booked">2:00 PM booked</div>
                  </div>
                  <div class="day-column">
                    <strong>Tue</strong>
                    <div class="slot booked">10:30 AM booked</div>
                    <div class="slot">3:30 PM open</div>
                  </div>
                  <div class="day-column">
                    <strong>Wed</strong>
                    <div class="slot">11:15 AM open</div>
                    <div class="slot booked">4:00 PM booked</div>
                  </div>
                  <div class="day-column">
                    <strong>Thu</strong>
                    <div class="slot">9:45 AM open</div>
                    <div class="slot">1:30 PM open</div>
                  </div>
                  <div class="day-column">
                    <strong>Fri</strong>
                    <div class="slot booked">12:00 PM booked</div>
                    <div class="slot">4:15 PM open</div>
                  </div>
                </div>
              </div>

              <div class="mock-card">
                <div class="summary-toolbar">
                  <div>
                    <h3 class="mini-title">Customer summary</h3>
                    <p class="mini-copy">Clean context after every call.</p>
                  </div>
                  <span class="soft-pill">Ready</span>
                </div>
                <div class="mock-card-pad">
                  <div class="summary-card">
                    <h3 class="mini-title">Jordan Lee</h3>
                    <p class="mini-copy">Asked about beard trim pricing and requested a Friday afternoon callback.</p>
                    <div class="summary-details">
                      <div><span>Status</span><strong>Follow up</strong></div>
                      <div><span>Number</span><strong>(555) 019-4420</strong></div>
                      <div><span>Source</span><strong>Voice call</strong></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section testimonials" id="testimonials" aria-labelledby="testimonials-title">
        <div class="shell">
          <div class="section-header">
            <p class="kicker">Customer stories</p>
            <h2 id="testimonials-title">Professional call handling without the extra front-desk hire.</h2>
          </div>
          <div class="testimonial-grid">
            {
              testimonials.map((testimonial) => (
                <blockquote class="testimonial">
                  <p>"{testimonial.quote}"</p>
                  <footer>{testimonial.name}</footer>
                </blockquote>
              ))
            }
          </div>
        </div>
      </section>

      <section class="section" aria-labelledby="final-title">
        <div class="shell final-cta">
          <h2 id="final-title">Give callers a better first answer.</h2>
          <p>
            Start with a simple plan, connect your calendar, and let EchoDesk answer the next call
            with calm consistency.
          </p>
          <div class="final-actions">
            <a class="button primary" href="#pricing">Compare plans</a>
            <a class="button" href="mailto:hello@echodesk.us?subject=EchoDesk%20setup">Talk to EchoDesk</a>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="shell footer-inner">
        <span>&copy; 2026 EchoDesk. All rights reserved.</span>
        <nav class="footer-links" aria-label="Legal links">
          <a href="/privacy.html">Privacy</a>
          <a href="/terms.html">Terms</a>
          <a href="/opt-in.html">Opt in</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
