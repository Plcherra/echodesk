---
const plans = [
  {
    name: "Free",
    price: "$0",
    minutes: "Test workspace",
    note: "For trying the app before connecting a business line.",
    cta: "Start free",
    href: "mailto:hello@echodesk.us?subject=Start%20EchoDesk%20Free",
    features: ["Mobile app access", "Create a receptionist", "Preview voice presets", "Connect Google Calendar"],
  },
  {
    name: "Starter",
    price: "$69",
    minutes: "400 minutes included",
    note: "For solo operators and small appointment-based businesses.",
    cta: "Choose Starter",
    href: "mailto:hello@echodesk.us?subject=EchoDesk%20Starter",
    featured: true,
    overage: "$0.35 / extra minute",
    features: ["AI call answering", "Calendar booking", "Call history and recordings", "Appointment review"],
  },
  {
    name: "Business",
    price: "$149",
    minutes: "1,200 minutes included",
    note: "For busier teams that need higher call coverage.",
    cta: "Choose Business",
    href: "mailto:hello@echodesk.us?subject=EchoDesk%20Business",
    overage: "$0.25 / extra minute",
    features: ["Everything in Starter", "Multiple receptionists", "Higher included usage", "Priority setup support"],
  },
  {
    name: "Enterprise",
    price: "Custom",
    minutes: "Custom minutes",
    note: "For multi-location operators and custom workflows.",
    cta: "Talk to us",
    href: "mailto:hello@echodesk.us?subject=EchoDesk%20Enterprise",
    overage: "Custom overage",
    features: ["Custom call routing", "Dedicated onboarding", "Compliance review", "Volume pricing"],
  },
];

const features = [
  {
    title: "Answers every call",
    text: "Give callers a calm, professional voice when you are with a client, closed, or simply busy.",
  },
  {
    title: "Books into your calendar",
    text: "EchoDesk checks real Google Calendar availability and creates appointments in the schedule you already use.",
  },
  {
    title: "Keeps the context",
    text: "Call history, recordings, appointment status, and receptionist settings stay organized in the mobile app.",
  },
  {
    title: "Built for service businesses",
    text: "Designed for salons, clinics, home services, studios, consultants, and teams that live by the calendar.",
  },
];

const testimonials = [
  {
    quote: "EchoDesk gives us a professional front desk without hiring another person. The calls feel calm and customers get booked.",
    name: "Local salon owner",
  },
  {
    quote: "The calendar connection is the part that matters. It does not just take messages, it helps turn calls into appointments.",
    name: "Independent service provider",
  },
  {
    quote: "I can see missed opportunities, recordings, and upcoming bookings from my phone. It feels simple and under control.",
    name: "Small business operator",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>EchoDesk | AI receptionist for appointment-based businesses</title>
    <meta
      name="description"
      content="EchoDesk is a calm, professional AI receptionist that answers calls, books appointments, and syncs with Google Calendar."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        color-scheme: light;
        --bg: #fbfaf8;
        --surface: #ffffff;
        --surface-soft: #f5f3f0;
        --ink: #15161a;
        --muted: #676b76;
        --soft: #8c9099;
        --line: #e4e0db;
        --line-strong: #c9c2bb;
        --brand: #58649b;
        --brand-dark: #343b66;
        --sage: #5b8068;
        --amber: #b87a3d;
        --shadow: 0 18px 50px rgba(40, 38, 35, 0.08);
        --shadow-soft: 0 12px 30px rgba(40, 38, 35, 0.06);
        --radius: 8px;
        --max: 1160px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: var(--ink);
        background: var(--bg);
        -webkit-font-smoothing: antialiased;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        display: block;
        max-width: 100%;
      }

      .shell {
        width: min(var(--max), calc(100% - 40px));
        margin: 0 auto;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 20;
        background: rgba(251, 250, 248, 0.9);
        backdrop-filter: blur(18px);
        border-bottom: 1px solid rgba(228, 224, 219, 0.82);
      }

      .nav {
        min-height: 72px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-weight: 700;
      }

      .brand-mark {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        background: var(--brand-dark);
        color: #fff;
        display: grid;
        place-items: center;
        font-size: 13px;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 28px;
        color: var(--muted);
        font-size: 14px;
      }

      .nav-actions {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: 0 18px;
        border-radius: 8px;
        border: 1px solid var(--line);
        font-size: 14px;
        font-weight: 700;
        background: var(--surface);
        color: var(--ink);
      }

      .button.primary {
        background: var(--brand-dark);
        border-color: var(--brand-dark);
        color: #fff;
      }

      .button.quiet {
        background: transparent;
      }

      .hero {
        padding: 96px 0 48px;
        border-bottom: 1px solid var(--line);
      }

      .hero-copy {
        max-width: 820px;
        margin: 0 auto;
        text-align: center;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--sage);
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 22px;
      }

      .eyebrow::before {
        content: "";
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--sage);
      }

      h1,
      h2,
      h3,
      p {
        margin: 0;
      }

      h1 {
        font-size: 64px;
        line-height: 1.04;
        letter-spacing: 0;
        font-weight: 700;
      }

      .hero-subtitle {
        max-width: 660px;
        margin: 24px auto 0;
        color: var(--muted);
        font-size: 20px;
        line-height: 1.65;
      }

      .hero-actions {
        margin-top: 32px;
        display: flex;
        justify-content: center;
        gap: 12px;
        flex-wrap: wrap;
      }

      .hero-note {
        margin-top: 18px;
        color: var(--soft);
        font-size: 14px;
      }

      .hero-media {
        margin-top: 62px;
      }

      .product-frame {
        overflow: hidden;
        border-radius: 8px;
        border: 1px solid var(--line);
        background: #ece9e5;
        box-shadow: var(--shadow);
      }

      .product-frame img {
        width: 100%;
        max-height: 560px;
        object-fit: cover;
        object-position: top center;
      }

      .trust-row {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1px;
        background: var(--line);
        border: 1px solid var(--line);
        border-top: 0;
        border-radius: 0 0 8px 8px;
        overflow: hidden;
      }

      .trust-item {
        background: var(--surface);
        padding: 18px;
        font-size: 14px;
        color: var(--muted);
      }

      .trust-item strong {
        display: block;
        margin-bottom: 4px;
        color: var(--ink);
        font-size: 15px;
      }

      .section {
        padding: 92px 0;
      }

      .section.compact {
        padding: 72px 0;
      }

      .section-header {
        max-width: 680px;
        margin-bottom: 42px;
      }

      .kicker {
        color: var(--brand);
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 12px;
      }

      h2 {
        font-size: 42px;
        line-height: 1.16;
        letter-spacing: 0;
      }

      .section-copy {
        margin-top: 16px;
        color: var(--muted);
        font-size: 18px;
        line-height: 1.65;
      }

      .pricing-section {
        background: var(--surface);
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
      }

      .pricing-layout {
        display: grid;
        grid-template-columns: 0.8fr 1.2fr;
        gap: 48px;
        align-items: start;
      }

      .pricing-summary {
        position: sticky;
        top: 104px;
      }

      .pricing-note {
        margin-top: 24px;
        padding: 18px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--surface-soft);
        color: var(--muted);
        font-size: 15px;
        line-height: 1.6;
      }

      .pricing-note strong {
        color: var(--ink);
      }

      .pricing-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
      }

      .plan {
        min-height: 410px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--surface);
        padding: 26px;
        display: flex;
        flex-direction: column;
        box-shadow: var(--shadow-soft);
      }

      .plan.featured {
        border-color: var(--brand-dark);
        box-shadow: 0 20px 50px rgba(52, 59, 102, 0.14);
      }

      .plan-label {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 18px;
      }

      .plan-name {
        font-size: 19px;
        font-weight: 700;
      }

      .recommended {
        border: 1px solid rgba(91, 128, 104, 0.26);
        background: rgba(91, 128, 104, 0.1);
        color: var(--sage);
        border-radius: 999px;
        padding: 5px 9px;
        font-size: 12px;
        font-weight: 700;
      }

      .price {
        display: flex;
        align-items: baseline;
        gap: 4px;
        margin-bottom: 8px;
      }

      .price strong {
        font-size: 40px;
        line-height: 1;
      }

      .price span {
        color: var(--muted);
        font-size: 15px;
      }

      .minutes {
        color: var(--brand-dark);
        font-weight: 700;
        margin-bottom: 10px;
      }

      .plan-note {
        color: var(--muted);
        font-size: 14px;
        line-height: 1.55;
      }

      .feature-list {
        list-style: none;
        padding: 0;
        margin: 24px 0;
        display: grid;
        gap: 10px;
        color: var(--muted);
        font-size: 14px;
      }

      .feature-list li {
        display: grid;
        grid-template-columns: 18px 1fr;
        gap: 8px;
      }

      .feature-list li::before {
        content: "✓";
        color: var(--sage);
        font-weight: 700;
      }

      .plan-footer {
        margin-top: auto;
        display: grid;
        gap: 12px;
      }

      .overage {
        color: var(--soft);
        font-size: 13px;
      }

      .features-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 16px;
      }

      .feature-card {
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--surface);
        padding: 24px;
        min-height: 210px;
      }

      .feature-number {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        display: grid;
        place-items: center;
        background: var(--surface-soft);
        color: var(--brand-dark);
        font-weight: 700;
        margin-bottom: 28px;
      }

      .feature-card h3 {
        font-size: 19px;
        margin-bottom: 12px;
      }

      .feature-card p {
        color: var(--muted);
        line-height: 1.6;
        font-size: 15px;
      }

      .showcase {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 28px;
        align-items: stretch;
      }

      .showcase-copy {
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--surface);
        padding: 34px;
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      .showcase-copy h2 {
        font-size: 36px;
      }

      .showcase-copy p {
        margin-top: 18px;
        color: var(--muted);
        font-size: 17px;
        line-height: 1.65;
      }

      .showcase-image {
        overflow: hidden;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: #ece9e5;
      }

      .showcase-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: top center;
      }

      .testimonials {
        background: var(--surface-soft);
        border-top: 1px solid var(--line);
      }

      .testimonial-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 16px;
      }

      .testimonial {
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--surface);
        padding: 26px;
      }

      .testimonial p {
        color: var(--ink);
        line-height: 1.65;
        font-size: 16px;
      }

      .testimonial footer {
        margin-top: 20px;
        color: var(--muted);
        font-size: 14px;
        font-weight: 700;
      }

      .final-cta {
        text-align: center;
        max-width: 720px;
        margin: 0 auto;
      }

      .final-cta p {
        margin-top: 18px;
        color: var(--muted);
        line-height: 1.65;
        font-size: 18px;
      }

      .final-actions {
        margin-top: 30px;
        display: flex;
        justify-content: center;
        gap: 12px;
        flex-wrap: wrap;
      }

      .site-footer {
        border-top: 1px solid var(--line);
        padding: 28px 0;
        color: var(--muted);
        font-size: 14px;
      }

      .footer-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        flex-wrap: wrap;
      }

      .footer-links {
        display: flex;
        gap: 20px;
      }

      @media (max-width: 980px) {
        .hero {
          padding-top: 76px;
        }

        h1 {
          font-size: 52px;
        }

        .pricing-layout {
          grid-template-columns: 1fr;
          gap: 32px;
        }

        .pricing-summary {
          position: static;
        }

        .features-grid,
        .trust-row {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .showcase,
        .testimonial-grid {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 760px) {
        .shell {
          width: min(var(--max), calc(100% - 28px));
        }

        .nav {
          min-height: 66px;
        }

        .nav-links {
          display: none;
        }

        .nav-actions .quiet {
          display: none;
        }

        h1 {
          font-size: 42px;
        }

        h2,
        .showcase-copy h2 {
          font-size: 32px;
        }

        .hero-subtitle {
          font-size: 18px;
        }

        .section {
          padding: 72px 0;
        }

        .pricing-grid,
        .features-grid,
        .trust-row {
          grid-template-columns: 1fr;
        }

        .product-frame img {
          max-height: 430px;
        }

        .button {
          width: 100%;
        }

        .nav-actions .button {
          width: auto;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="shell nav">
        <a class="brand" href="#top" aria-label="EchoDesk home">
          <span class="brand-mark">ED</span>
          <span>EchoDesk</span>
        </a>
        <nav class="nav-links" aria-label="Primary navigation">
          <a href="#pricing">Pricing</a>
          <a href="#features">Features</a>
          <a href="#product">Product</a>
          <a href="#testimonials">Stories</a>
        </nav>
        <div class="nav-actions">
          <a class="button quiet" href="mailto:hello@echodesk.us">Contact</a>
          <a class="button primary" href="#pricing">See pricing</a>
        </div>
      </div>
    </header>

    <main id="top">
      <section class="hero" aria-labelledby="hero-title">
        <div class="shell">
          <div class="hero-copy">
            <p class="eyebrow">AI receptionist for appointment-based businesses</p>
            <h1 id="hero-title">Answer every call. Book more appointments.</h1>
            <p class="hero-subtitle">
              EchoDesk gives your business a calm, professional receptionist that answers calls,
              checks your calendar, and books customers while you stay focused on the work.
            </p>
            <div class="hero-actions">
              <a class="button primary" href="#pricing">View plans</a>
              <a class="button" href="mailto:hello@echodesk.us?subject=EchoDesk%20demo">Request a demo</a>
            </div>
            <p class="hero-note">Starter plans from $69/month. Clear minutes, fair overage, no long-term contract.</p>
          </div>

          <div class="hero-media" aria-label="EchoDesk dashboard preview">
            <div class="product-frame">
              <img
                src="/images/dashboard-overview.png"
                alt="EchoDesk mobile dashboard showing calls, appointments, receptionists, and included minutes"
                width="944"
                height="2048"
              />
            </div>
            <div class="trust-row" aria-label="Product highlights">
              <div class="trust-item"><strong>24/7 coverage</strong>Never send callers to silence.</div>
              <div class="trust-item"><strong>Calendar-first</strong>Books into Google Calendar.</div>
              <div class="trust-item"><strong>Mobile control</strong>Manage calls from your phone.</div>
              <div class="trust-item"><strong>Clear pricing</strong>Included minutes and fair overage.</div>
            </div>
          </div>
        </div>
      </section>

      <section class="section pricing-section" id="pricing" aria-labelledby="pricing-title">
        <div class="shell pricing-layout">
          <div class="pricing-summary">
            <p class="kicker">Pricing</p>
            <h2 id="pricing-title">Simple plans built around call minutes.</h2>
            <p class="section-copy">
              Pick the amount of receptionist coverage you need. Upgrade as your call volume grows,
              and keep overage predictable when a busy month happens.
            </p>
            <div class="pricing-note">
              <strong>Overage:</strong> extra minutes are billed at $0.25-$0.35 per minute depending on plan.
              Enterprise plans can use custom volume pricing.
            </div>
          </div>

          <div class="pricing-grid">
            {
              plans.map((plan) => (
                <article class:list={["plan", { featured: plan.featured }]}>
                  <div class="plan-label">
                    <h3 class="plan-name">{plan.name}</h3>
                    {plan.featured && <span class="recommended">Recommended</span>}
                  </div>
                  <div class="price">
                    <strong>{plan.price}</strong>
                    {plan.price !== "Custom" && <span>/ month</span>}
                  </div>
                  <p class="minutes">{plan.minutes}</p>
                  <p class="plan-note">{plan.note}</p>
                  <ul class="feature-list">
                    {plan.features.map((feature) => <li>{feature}</li>)}
                  </ul>
                  <div class="plan-footer">
                    {plan.overage && <p class="overage">Overage: {plan.overage}</p>}
                    <a class:list={["button", { primary: plan.featured }]} href={plan.href}>{plan.cta}</a>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section class="section" id="features" aria-labelledby="features-title">
        <div class="shell">
          <div class="section-header">
            <p class="kicker">What it does</p>
            <h2 id="features-title">A front desk that stays focused on booking.</h2>
            <p class="section-copy">
              EchoDesk keeps the workflow simple: answer, understand, check availability,
              book, and keep the record available for review.
            </p>
          </div>
          <div class="features-grid">
            {
              features.map((feature, index) => (
                <article class="feature-card">
                  <div class="feature-number">{index + 1}</div>
                  <h3>{feature.title}</h3>
                  <p>{feature.text}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section class="section compact" id="product" aria-labelledby="product-title">
        <div class="shell showcase">
          <div class="showcase-copy">
            <p class="kicker">Product</p>
            <h2 id="product-title">Review calls, recordings, and appointments from one calm workspace.</h2>
            <p>
              Every call creates a record your team can understand. Open the call, review the outcome,
              play the recording, and see the appointment that was booked.
            </p>
          </div>
          <div class="showcase-image">
            <img
              src="/images/call-details-recording.png"
              alt="EchoDesk call details screen with call outcome, recording actions, and caller information"
              width="944"
              height="2048"
            />
          </div>
        </div>
      </section>

      <section class="section testimonials" id="testimonials" aria-labelledby="testimonials-title">
        <div class="shell">
          <div class="section-header">
            <p class="kicker">Customer stories</p>
            <h2 id="testimonials-title">Professional call handling without the extra front-desk hire.</h2>
          </div>
          <div class="testimonial-grid">
            {
              testimonials.map((testimonial) => (
                <blockquote class="testimonial">
                  <p>“{testimonial.quote}”</p>
                  <footer>{testimonial.name}</footer>
                </blockquote>
              ))
            }
          </div>
        </div>
      </section>

      <section class="section" aria-labelledby="final-title">
        <div class="shell final-cta">
          <h2 id="final-title">Give callers a better first answer.</h2>
          <p>
            Start with a simple plan, connect your calendar, and let EchoDesk answer the next call
            with the same calm consistency every time.
          </p>
          <div class="final-actions">
            <a class="button primary" href="#pricing">Compare plans</a>
            <a class="button" href="mailto:hello@echodesk.us?subject=EchoDesk%20setup">Talk to EchoDesk</a>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="shell footer-inner">
        <span>© 2026 EchoDesk. All rights reserved.</span>
        <nav class="footer-links" aria-label="Legal links">
          <a href="/privacy.html">Privacy</a>
          <a href="/terms.html">Terms</a>
          <a href="/opt-in.html">Opt in</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
